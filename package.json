{
  "name": "base-api-template",
  "version": "1.0.0",
  "private": true,
  "description": "Fastify API template with Drizzle ORM and AWS S3 support",
  "main": "build/src/index.js",
  "scripts": {
    "start": "node build/src/index.js",
    "dev": "nodemon",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "vercel-build": "tsc -p tsconfig.json",
    "vercel": "node build/src/index.js"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1089.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/swagger": "^9.8.1",
    "@fastify/swagger-ui": "^5.2.6",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.9.0",
    "jsonwebtoken": "^9.0.3",
    "mime-types": "^3.0.2",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.20.0",
    "@types/pg": "^8.20.0",
    "@vercel/node": "^4.0.0",
    "drizzle-kit": "^0.31.9",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  }
}
